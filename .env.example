# Database Configuration
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_DATABASE=postpulse
MYSQL_USER=postpulseuser
MYSQL_PASSWORD=your_user_password_here

# App Connection
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/postpulse
SPRING_DATASOURCE_USERNAME=postpulseuser
SPRING_DATASOURCE_PASSWORD=your_user_password_here
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# JWT Configuration
JWT_SECRET_KEY=your_secret_key_here_replace_with_a_secure_random_string
JWT_EXPIRATION_MILLISECONDS=604800000